# Landing (chato-web) — variables públicas.
#
# Todas son NEXT_PUBLIC_* → se embeben en el bundle en BUILD TIME.
# En Dokploy cargalas como BUILD ARGUMENTS (no como runtime env).
#
# Fuente de verdad: src/lib/config.ts. Cambiar de dominio/correo = cambiar
# estos valores en un solo lugar (no se toca código). Si no se setean, el
# código cae a los defaults (dominio actual) para no romper nada.

# --- Dominios por servicio ---
# Landing / sitio comercial (este app)
NEXT_PUBLIC_LANDING_URL=https://chato.xerebrumgroup.com
# Dashboard (chato-app)
NEXT_PUBLIC_APP_URL=https://chato-app.xerebrumgroup.com
# Backend API (chato-api)
NEXT_PUBLIC_API_URL=https://chato-api.xerebrumgroup.com

# En el cutover a producción, por ejemplo:
# NEXT_PUBLIC_LANDING_URL=https://heychato.com
# NEXT_PUBLIC_APP_URL=https://app.heychato.com
# NEXT_PUBLIC_API_URL=https://api.heychato.com

# --- Correos de contacto ---
# Privacidad / legal / eliminación de datos (páginas legales)
NEXT_PUBLIC_LEGAL_EMAIL=privacidad@chato.app
# Contacto / soporte general (footer). Si se omite, usa el legal.
NEXT_PUBLIC_CONTACT_EMAIL=privacidad@chato.app
